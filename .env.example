# -------------------------
# Database (Supabase Postgres)
# -------------------------
# Recommended: use the Postgres connection string from Supabase:
#   Project Settings → Database → Connection string
# Example format:
#   postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
#
# Notes:
# - Supabase requires SSL; this backend auto-sets sslmode=require for supabase.co hosts.
# - If you need to override SSL mode, set DATABASE_SSLMODE=require|verify-ca|verify-full
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
DATABASE_SSLMODE=require

# Optional: auto-create tables at startup (fine for school projects; disable if you manage schema yourself)
CREATE_TABLES=true

# -------------------------
# Google Gemini (for RAG/Chat)
# -------------------------
GOOGLE_API_KEY=YOUR_KEY_HERE

# Knowledge Base
KNOWLEDGE_BASE_DIR=../knowledge_base

# RAG settings
RAG_K_BM25=2
RAG_K_PAGES=2
RAG_K_PER_PAGE=1
RAG_K_FINAL=3
RAG_PAGE_TEXT_MAX_CHARS=1200
RAG_MIN_RELEVANCE=0.35

# LLM performance/safety toggles
RAG_ENABLE_SAFETY=false
RAG_LLM_TIMEOUT=60
RAG_LLM_MAX_RETRIES=1

# Frontend HTTP client timeout (seconds)
HTTP_TIMEOUT_S=180

# MLflow (optional)
# Local non-Docker example: file:./mlruns
# Docker Compose overrides this to http://mlflow:5000 for backend/scheduler containers.
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=pet-nutrition-rag
MLFLOW_RUN_TAG_PIPELINE=scheduled
ENABLE_MLFLOW_CHAT_LOGGING=true

# -------------------------
# MLOps Scheduler (optional)
# -------------------------
REBUILD_EVERY_DAYS=3
SCHEDULER_RUN_ON_START=true
ENABLE_DVC_PUSH=false
